# --- Brokers / data vendors ---
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.market

POLYGON_API_KEY=your_key_here
TIINGO_API_KEY=your_key_here

# --- Database (Timescale via docker compose) ---
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
POSTGRES_DB=quant
DATABASE_URL=postgresql+psycopg://quant:quant@localhost:5432/quant

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@local
PGADMIN_DEFAULT_PASSWORD=admin

# --- MinIO (S3-compat) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=quant-data

# --- Jupyter ---
JUPYTER_TOKEN=quant

# --- Local data ---
DATA_DIR=./data
